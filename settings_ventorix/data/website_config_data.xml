<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- Set website languages: English (primary) + Czech -->
    <record id="website.default_website" model="website">
        <field name="default_lang_id" ref="base.lang_en"/>
        <field name="language_ids" eval="[(6, 0, [
            ref('base.lang_en'),
            ref('base.lang_cs_CZ'),
        ])]"/>
    </record>

</data>
</odoo>
