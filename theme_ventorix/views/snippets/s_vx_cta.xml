<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_vx_cta" name="Ventorix CTA Section">
    <section class="s_vx_cta o_cc o_cc5 o_colored_level py-5 position-relative overflow-hidden"
             style="background: linear-gradient(135deg, #1B3A5C 0%, #0A1628 100%);">
        <!-- Background image -->
        <div class="position-absolute w-100 h-100"
             style="top: 0; left: 0;
                    background-image: url('/theme_ventorix/static/src/img/steel-pipes.jpg');
                    background-size: cover; background-position: center;
                    opacity: 0.08;"/>
        <!-- Glow accent -->
        <div class="position-absolute"
             style="top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, #2E86DE, transparent); opacity: 0.4;"/>

        <div class="container position-relative text-center py-5" style="z-index: 2;">
            <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                <div class="vx_accent_line_left"/>
                <span class="vx_accent_label" style="font-size: 0.75rem;">
                    Start Your Project
                </span>
                <div class="vx_accent_line_right"/>
            </div>
            <h2 class="vx_heading_light" style="font-size: 2.75rem;">
                Need Industrial Piping<br/>Materials?
            </h2>
            <p class="vx_text_body_dark" style="font-size: 1.05rem; max-width: 540px; margin: 0 auto 1.5rem;">
                Upload your specs, select your materials, and receive a competitive
                quotation within 48 hours. No commitment required.
            </p>

            <!-- Trust indicators -->
            <div class="d-flex flex-wrap justify-content-center gap-4 mb-4">
                <span class="vx_text_muted_dark" style="font-size: 0.8rem;">
                    <i class="fa fa-check me-1" style="color: #2E86DE;"/>DIN / ANSI / API
                </span>
                <span class="vx_text_muted_dark" style="font-size: 0.8rem;">
                    <i class="fa fa-check me-1" style="color: #2E86DE;"/>MTC 3.1 Included
                </span>
                <span class="vx_text_muted_dark" style="font-size: 0.8rem;">
                    <i class="fa fa-check me-1" style="color: #2E86DE;"/>50+ Countries
                </span>
            </div>

            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="/contact#quote" class="btn vx_btn_white px-5 py-3"
                   style="font-size: 0.95rem;">
                    <i class="fa fa-paper-plane me-2"/>Get Quotation
                </a>
                <a href="/products" class="btn vx_btn_outline px-5 py-3"
                   style="font-size: 0.95rem;">
                    View Catalog
                </a>
            </div>
        </div>
    </section>
</template>

</odoo>
