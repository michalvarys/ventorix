<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_vx_hero" name="Ventorix Hero Banner">
    <section class="s_vx_hero o_cc o_cc5 position-relative overflow-hidden"
             style="min-height: 100vh;">
        <!-- Background image -->
        <div class="position-absolute w-100 h-100"
             style="top: 0; left: 0;
                    background-image: url('/theme_ventorix/static/src/img/hero-industrial.jpg');
                    background-size: cover; background-position: center;
                    opacity: 0.25;"/>
        <!-- Gradient overlay -->
        <div class="position-absolute w-100 h-100"
             style="top: 0; left: 0;
                    background: linear-gradient(160deg, rgba(10,22,40,0.95) 0%, rgba(14,31,56,0.85) 50%, rgba(27,58,92,0.75) 100%);"/>
        <!-- Geometric decorative corners -->
        <div class="position-absolute" style="top: 3rem; left: 3rem; width: 100px; height: 100px; border-left: 2px solid rgba(46,134,222,0.2); border-top: 2px solid rgba(46,134,222,0.2); z-index: 2;"/>
        <div class="position-absolute" style="bottom: 3rem; right: 3rem; width: 100px; height: 100px; border-right: 2px solid rgba(46,134,222,0.2); border-bottom: 2px solid rgba(46,134,222,0.2); z-index: 2;"/>

        <div class="container position-relative" style="z-index: 3;">
            <div class="row min-vh-100 align-items-center">
                <div class="col-lg-8 col-xl-7 py-5">
                    <!-- Label with accent line -->
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="vx_accent_line"/>
                        <span class="vx_accent_label" style="font-size: 0.85rem;">
                            Global Industrial Partner
                        </span>
                    </div>

                    <!-- Main title -->
                    <h1 style="font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 3.75rem; line-height: 1.08; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 1.5rem;">
                        Premium Flanges,<br/>
                        Pipes &amp; Pipeline<br/>
                        <span class="vx_gradient_text">Components</span>
                    </h1>

                    <!-- Subtitle -->
                    <p class="vx_text_body_dark" style="font-size: 1.125rem; max-width: 520px; line-height: 1.8; margin-bottom: 2.5rem;">
                        Direct manufacturing oversight in China. DIN/ANSI certified materials.
                        European quality standards at competitive pricing.
                    </p>

                    <!-- CTA buttons -->
                    <div class="d-flex flex-wrap gap-3 mb-5">
                        <a href="/contact#quote" class="btn vx_btn_primary px-5 py-3"
                           style="font-size: 0.9rem;">
                            Request Quote
                        </a>
                        <a href="/products" class="btn vx_btn_outline px-5 py-3"
                           style="font-size: 0.9rem;">
                            View Catalog
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats bar at bottom -->
        <div class="position-relative" style="z-index: 3; background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.08);">
            <div class="container">
                <div class="row text-center py-4">
                    <div class="col-3">
                        <div class="vx_stat_accent" style="font-size: 2.25rem;">1000+</div>
                        <div class="vx_text_subtle_dark" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 500;">Products</div>
                    </div>
                    <div class="col-3" style="border-left: 1px solid rgba(255,255,255,0.08);">
                        <div class="vx_stat_accent" style="font-size: 2.25rem;">50+</div>
                        <div class="vx_text_subtle_dark" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 500;">Countries</div>
                    </div>
                    <div class="col-3" style="border-left: 1px solid rgba(255,255,255,0.08);">
                        <div class="vx_stat_accent" style="font-size: 2.25rem;">24/7</div>
                        <div class="vx_text_subtle_dark" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 500;">Support</div>
                    </div>
                    <div class="col-3" style="border-left: 1px solid rgba(255,255,255,0.08);">
                        <div class="vx_stat_accent" style="font-size: 2.25rem;">ISO</div>
                        <div class="vx_text_subtle_dark" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 500;">Certified</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
